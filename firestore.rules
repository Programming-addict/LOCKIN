rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function roomExists(code) {
      return exists(/databases/$(database)/documents/studyRooms/$(code));
    }

    function isRoomHost(code) {
      return isSignedIn()
        && roomExists(code)
        && get(/databases/$(database)/documents/studyRooms/$(code)).data.hostUid == request.auth.uid;
    }

    match /users/{uid}/lockin/sync {
      allow read, write: if isOwner(uid);
    }

    match /leaderboard/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    match /studyRooms/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.hostUid == request.auth.uid;
      allow update: if isRoomHost(code);
      allow delete: if isRoomHost(code);

      match /members/{uid} {
        allow read: if isSignedIn();
        allow create, update: if isOwner(uid);
        allow delete: if isOwner(uid) || isRoomHost(code);
      }
    }
  }
}
